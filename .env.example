# Lumora Intelligence — Environment Variables
# Bu dosyayı .env olarak kopyalayın ve değerleri doldurun:
# cp .env.example .env

# ─── Servis ───────────────────────────────────────────────────────────
APP_ENV=production
INTELLIGENCE_HOST=0.0.0.0
INTELLIGENCE_PORT=8001

# İç servis güvenlik anahtarı (Backend ile aynı olmalı!)
INTERNAL_API_KEY=change-this-to-a-strong-secret-key

# ─── PostgreSQL ───────────────────────────────────────────────────────
# VPS'de backend ile aynı DB'yi kullanır
POSTGRESQL_HOST=localhost
POSTGRESQL_PORT=5432
POSTGRESQL_DATABASE=lumora_db
POSTGRESQL_USERNAME=postgres
POSTGRESQL_PASSWORD=your-db-password-here

# ─── Backend Callback URL ─────────────────────────────────────────────
# Intelligence scoring bitince backend'e bildirim gönderir
# VPS'de nginx arkasındaysa internal URL kullanın:
BACKEND_CALLBACK_URL=http://localhost:8000/api/intelligence/callback

# ─── APScheduler ─────────────────────────────────────────────────────
NIGHTLY_BATCH_HOUR=2
NIGHTLY_BATCH_MINUTE=0
WEEKLY_RETRAIN_DAY=sun
WEEKLY_RETRAIN_HOUR=3

# ─── Engine Parametreleri (genellikle değiştirmeye gerek yok) ─────────
CATBOOST_ITERATIONS=500
CATBOOST_LEARNING_RATE=0.05
CATBOOST_DEPTH=6
MIN_DAYS_FOR_CATBOOST=30
